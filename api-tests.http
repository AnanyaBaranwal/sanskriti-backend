### ─── Test 1: Health Check ────────────────────────────────────
# @name healthCheck
GET {{baseUrl}}/health

### ─── Test 2: Register Seller ────────────────────────
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Ananya Seller",
  "email": "ananya@sanskriti.com",
  "password": "password123",
  "phone": "9876543210"
}

### ─── Test 3: Login ──────────────────────────────────────────
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "ananya@sanskriti.com",
  "password": "newpassword456"
}


### ─── Test 4: Get My Profile (paste token from Test 3 above) ─
# @name getMe
GET {{baseUrl}}/auth/me
Authorization: Bearer {{token}}


### ─── Test 5: Logout ─────────────────────────────────────────
# @name logout
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{token}}


### ─── Test 6: Try wrong password (should return 401) ─────────
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "test@sanskriti.com",
  "password": "wrongpassword"
}


### ─── Test 7: Register duplicate email (should return 409) ───
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Test Seller",
  "email": "test@sanskriti.com",
  "phone": "9876543210",
  "password": "mypassword123"
}

### ====================================================
### DAY 2 TESTS — JWT Refresh Token System
### ====================================================

### ─── Test 6: Refresh Token (get new accessToken) ───
# Run this AFTER login. Uses the refreshToken cookie automatically.
# @name refreshToken
POST {{baseUrl}}/auth/refresh-token
Cookie: refreshToken=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5ZjM1OWJmNjNlMzE1NDIzOTI5Y2EyMyIsImlhdCI6MTc3NzYxMzQxOCwiZXhwIjoxNzc4MjE4MjE4fQ.o_OhOWdsrwKU9smtsFN-g3W07HmVejySKh517wM2yHE

### ─── Test 7: Forgot Password ───────────────────────
# @name forgotPassword
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "email": "test@sanskriti.com"
}


### ─── Test 8: Reset Password ────────────────────────
# Paste the token from your email here in the URL
# @name resetPassword
POST {{baseUrl}}/auth/reset-password/1d474d800510f1758c12fc3e7df4d94e8206736ae6d7439752f85c8cbcdf2365
Content-Type: application/json

{
  "password": "newpassword123"
}


### ─── Test 9: Verify token rotation ─────────────────
# After running Test 6, try using the OLD refresh token again
# Send this request — should return 401 TOKEN_REUSE_DETECTED
# This proves each refresh token can only be used once
POST {{baseUrl}}/auth/refresh-token
Cookie: refreshToken=PASTE_OLD_REFRESH_TOKEN_HERE
### ====================================================
### DAY 3 TESTS — Seller Profile + KYC
### ====================================================

### ─── Test D3-1: Get Profile ─────────────────────────
GET {{baseUrl}}/seller/profile
Authorization: Bearer {{token}}


### ─── Test D3-2: Update Profile ─────────────────────
PATCH {{baseUrl}}/seller/profile
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Ananya Seller",
  "phone": "9876543210",
  "address": {
    "street": "123 MG Road",
    "city": "Lucknow",
    "state": "Uttar Pradesh",
    "pincode": "226001"
  }
}


### ─── Test D3-3: Update Business Details ─────────────
PATCH {{baseUrl}}/seller/business
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "businessName": "Sanskriti Creations",
  "gstNumber": "09ABCDE1234F1Z5",
  "address": {
    "street": "456 Hazratganj",
    "city": "Lucknow",
    "state": "Uttar Pradesh",
    "pincode": "226001"
  }
}


### ─── Test D3-4: Submit KYC Details ─────────────────
POST {{baseUrl}}/seller/kyc/upload
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "panNumber": "ABCDE1234F",
  "aadharNumber": "1234 5678 9012",
  "bankAccountNumber": "1234567890",
  "bankIFSC": "SBIN0001234",
  "bankAccountName": "Ananya Baranwal"
}


### ─── Test D3-5: Get KYC Status ──────────────────────
GET {{baseUrl}}/seller/kyc
Authorization: Bearer {{token}}


### ─── Test D3-6: Change Password ────────────────────
PATCH {{baseUrl}}/seller/change-password
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "currentPassword": "password123",
  "newPassword": "newpassword456"
}
