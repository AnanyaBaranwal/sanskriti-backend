  "accountNumber": "1234567890",
  "ifscCode": "SBIN0001234",
  "accountName": "Ananya Baranwal",
  "bankName": "State Bank of India",
  "sellerNote": "Monthly payout request"
}


### ─── Test PO2: Get My Payouts ───────────────────────
GET {{baseUrl}}/payouts/my
Authorization: Bearer {{token}}


### ─── Test PO3: Get Single Payout ───────────────────
# Paste payout _id from PO1 response
GET {{baseUrl}}/payouts/69f5ce0245c580403c0fce7a
Authorization: Bearer {{token}}


### ─── Test PO4: Try Duplicate Request (should fail) ─
POST {{baseUrl}}/payouts/request
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount": 200,
  "accountNumber": "1234567890",
  "ifscCode": "SBIN0001234",
  "accountName": "Ananya Baranwal"
}


### ─── Test PO5: Cancel Payout ────────────────────────
